# Copy this to .env.local for local development
# In Vercel: add each variable under Project Settings → Environment Variables

# ── Database (Neon PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Better Auth ───────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=https://your-project.vercel.app

# ── Google OAuth (optional) ───────────────────────────────────
# Get from https://console.developers.google.com
# Authorized redirect URI: https://your-project.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Gemini AI ──────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-pro

# ── Vercel Blob Storage ───────────────────────────────────────
# Auto-provided by Vercel when you add Blob storage to the project
BLOB_READ_WRITE_TOKEN=

# ── Ollama (local dev only — not needed on Vercel) ────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Migration secret (for /api/run-migration endpoint) ────────
MIGRATION_SECRET=change-this-to-a-random-string
